# HiveMind OS Web UI

# PostgreSQL（与 memory_layer 共用）
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/hivemindos"

# NextAuth / Auth.js v5
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# KB BFF 代理目标（FastAPI）
KB_API_BASE_URL="http://localhost:8006"

# 未登录时的兜底 org（开发用，生产应走登录 session）
NEXT_PUBLIC_KB_DEFAULT_ORG="demo"
