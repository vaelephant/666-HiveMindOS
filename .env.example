OPENAI_API_KEY=sk-...

# 主模型（OpenAI）— 覆盖 models.yaml 中 default / fast 的 model id
DEFAULT_MODEL=gpt-4o
FAST_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# 可选：按需使用 Anthropic profile（prompts.yaml → model: anthropic_strong）
# ANTHROPIC_API_KEY=sk-ant-...

# 运行时数据根目录。后端从 backend/ 启动，相对路径会基于 backend/ 解析，
# 易与仓库根 storage/ 混淆 —— 建议填【绝对路径】固定下来。
# 例：STORAGE_ROOT=/Users/you/code/666-HiveMindOS/storage
STORAGE_ROOT=backend/knowledge_base/storage

# PostgreSQL（Memory Layer：聊天记录 + 结构化记忆）
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=hivemindos
DATABASE_URL=postgresql://your_user:your_password@localhost:5432/hivemindos

# Qdrant — 智慧语义检索（P3）
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=hivemind_memories
QDRANT_ENABLED=true

# Embedding 维度由 model_layer/settings/models.yaml → profiles.embedding.dim 定义
# 更换 embedding provider/model 后需重建向量：python scripts/sync_memory_vectors.py

# 企业微信（可选开发兜底；生产请在 Web UI → 集成 按组织配置）
# WECHAT_WORK_CORP_ID=
# WECHAT_WORK_AGENT_ID=
# WECHAT_WORK_SECRET=
# WECHAT_WORK_TOKEN=
# WECHAT_WORK_ENCODING_AES_KEY=
