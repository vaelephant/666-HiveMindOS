OPENAI_API_KEY=sk-...

# 主模型（OpenAI）— 覆盖 models.yaml 中 default / fast 的 model id
DEFAULT_MODEL=gpt-4o
FAST_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# 可选：按需使用 Anthropic profile（prompts.yaml → model: anthropic_strong）
# ANTHROPIC_API_KEY=sk-ant-...

# 运行时数据根目录（相对路径相对【仓库根】解析，推荐 STORAGE_ROOT=storage）
STORAGE_ROOT=storage

# PostgreSQL（Memory Layer：聊天记录 + 结构化记忆）
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=hivemindos
DATABASE_URL=postgresql://your_user:your_password@localhost:5432/hivemindos

# Qdrant — 智慧语义检索（P3）
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=hivemind_memories
QDRANT_ENABLED=true

# Embedding 维度由 model_layer/settings/models.yaml → profiles.embedding.dim 定义
# 更换 embedding provider/model 后需重建向量：python scripts/sync_memory_vectors.py

# 启动连通自检（Postgres / Qdrant / 大模型）
# STARTUP_HEALTHCHECK=true        # 总开关，false 时启动只打印配置、不做网络自检
# STARTUP_HEALTHCHECK_TIMEOUT=5   # 单项自检超时秒数（并行执行，共享 deadline）
# STARTUP_LLM_PING=false          # true 时启动额外真发一次 chat 请求实测（默认只校验 key）

# 配置归属提醒：
# - OPENAI_API_KEY 等密钥只需在【一处】维护。加载顺序为 根 .env → webui/.env(override)，
#   两处都填且不一致时以 webui/.env 为准，易踩"改了根 .env 不生效"的坑。
# - 后端未使用 Redis，webui/.env 里的 REDIS_* 对本服务无效。

# 企业微信（可选开发兜底；生产请在 Web UI → 集成 按组织配置）
# WECHAT_WORK_CORP_ID=
# WECHAT_WORK_AGENT_ID=
# WECHAT_WORK_SECRET=
# WECHAT_WORK_TOKEN=
# WECHAT_WORK_ENCODING_AES_KEY=
