ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_MODEL=claude-opus-4-7
FAST_MODEL=claude-sonnet-4-6
STORAGE_ROOT=memory_layer/knowledge_base/storage

# PostgreSQL（Memory Layer：聊天记录 + 结构化记忆）
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=hivemindos
DATABASE_URL=postgresql://your_user:your_password@localhost:5432/hivemindos

# Qdrant — 智慧语义检索（P3）
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=hivemind_memories
QDRANT_ENABLED=true

# OpenAI Embeddings（text-embedding-3-small）
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
